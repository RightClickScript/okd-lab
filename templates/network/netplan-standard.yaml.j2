network:
  version: 2
  renderer: networkd
  ethernets:
    {{ physical_iface }}:
      dhcp4: no
  bonds:
    bond0:
      interfaces:
        - {{ physical_iface }}
      parameters:
        mode: active-backup
        mii-monitor-interval: 100
  bridges:
    # br0: Management Network (VLAN 199 Untagged)
    br0:
      interfaces: [bond0]
      addresses:
        - {{ ansible_host }}/24
{% if ansible_host == '192.168.199.5' %}
        - {{ network.okd_lb_ip }}/24
        - {{ network.netboot_ip }}/24
{% endif %}
      routes:
        - to: default
          via: {{ network.mgmt_gateway }}
      nameservers:
        # Hierarchical DNS: Windows DC (.10) first, then UniFi (.1)
        addresses: [{{ network.primary_dns }}, {{ network.secondary_dns }}]
        search: {{ network.search_domains }}
      parameters:
        stp: no

    # br198: Compute/VM Network (VLAN 198 Tagged)
    br198:
      interfaces: [vlan{{ network.vlan198_id }}]
      dhcp4: yes
      parameters:
        stp: no

  vlans:
    vlan{{ network.vlan198_id }}:
      id: {{ network.vlan198_id }}
      link: bond0
